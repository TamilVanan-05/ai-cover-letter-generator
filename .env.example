# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=super-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Database Configuration
# Dev (SQLite): sqlite:///database.db
# Prod (MySQL): mysql+pymysql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///database.db

# AI API Key (Optional: Falls back to built-in high-quality local NLP generation)
GEMINI_API_KEY=

# Server Port
PORT=5000
